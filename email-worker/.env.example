# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env com senhas reais.

# String de conexão com o PostgreSQL
DB_CONNECTION_STRING=Host=localhost;Database=projeto_utc;Username=postgres;Password=SUA_SENHA

